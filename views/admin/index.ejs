                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <select id="formStatus"
                  class="w-full pl-11 pr-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand text-white appearance-none transition-all shadow-inner cursor-pointer">
