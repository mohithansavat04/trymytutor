              class="hidden px-6 py-2.5 bg-brand text-white font-medium rounded-lg shadow-lg shadow-brand/30 hover:-translate-y-0.5 hover:shadow-brand/50 transition-all items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6">
