<div id="cmsContent" class="hidden w-full">
          <div class="glass-card border border-brand-border rounded-2xl p-6">
            <div class="flex justify-between items-center mb-6 pb-6 border-b border-brand-border">
              <h3 class="text-xl font-bold">CMS Management</h3>
              <button onclick="openCmsModal()" class="bg-brand hover:bg-orange-500 text-white font-medium py-2 px-4 rounded-xl transition-colors">
                + Create Page
              </button>
            </div>
            <div id="cmsTableContainer" class="w-full"></div>
          </div>
        </div>

        <!-- CMS Modal (Create / Edit) -->
        <div id="cmsModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex items-center justify-center">
          <div class="bg-slate-900 border border-brand-border rounded-2xl p-6 w-full max-w-2xl">
            <h3 id="cmsModalTitle" class="text-xl font-bold text-white mb-4">Create Page</h3>
            <input type="hidden" id="cmsId">
            <div class="grid grid-cols-2 gap-4">
              <div class="mb-4">
                <label class="block text-sm font-medium text-slate-300 mb-2">Title</label>
                <input type="text" id="cmsTitle" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white">
              </div>
              <div class="mb-4">
                <label class="block text-sm font-medium text-slate-300 mb-2">Slug</label>
                <input type="text" id="cmsSlug" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white" placeholder="e.g. about-us">
              </div>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-medium text-slate-300 mb-2">Content (HTML allowed)</label>
              <textarea id="cmsBodyContent" rows="6" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white font-mono text-sm"></textarea>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-medium text-slate-300 mb-2">Status</label>
              <select id="cmsStatus" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
              </select>
            </div>
            <div class="flex justify-end gap-3 mt-6">
              <button type="button" onclick="closeCmsModal()" class="px-4 py-2 text-sm font-medium text-slate-400 hover:text-white transition-colors">Cancel</button>
              <button type="button" onclick="submitCms()" class="px-4 py-2 text-sm font-medium bg-brand text-white rounded-lg hover:bg-orange-500 transition-colors">Save Page</button>
            </div>
          </div>
        </div>