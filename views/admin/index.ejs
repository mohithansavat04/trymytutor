        <form id="mcqForm" class="flex flex-col">
          <input type="hidden" id="formMcqId">

          <div class="group mb-6">
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Question
              Text</label>
            <textarea id="formMcqQuestion" required rows="3" placeholder="Type the agreement question here..."
              class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand text-white placeholder-slate-600 transition-all shadow-inner"></textarea>
          </div>

