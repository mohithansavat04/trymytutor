<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin TryMyTutor</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              DEFAULT: '#f97316', // Vibrant Orange
              hover: '#ea580c',
              dark: '#0f172a',    // Deep Blue
              card: 'rgba(30, 41, 59, 0.6)',
              border: 'rgba(255, 255, 255, 0.1)',
            }
          },
          fontFamily: {
            sans: ['Outfit', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Custom CSS for animations/overrides -->
  <link rel="stylesheet" href="/admin/css/styles.css">
</head>

<body class="bg-brand-dark text-slate-100 min-h-screen relative overflow-x-hidden font-sans custom-bg">

  <!-- ======================= -->
  <!--       LOGIN VIEW        -->
  <!-- ======================= -->
  <div class="view-section active flex items-center justify-center min-h-screen p-4" id="loginView">
    <div class="glass-card w-full max-w-md p-10 rounded-2xl shadow-2xl relative z-10 animate-slide-up">
      <h2
        class="text-3xl font-bold mb-6 text-center bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400">
        TryMyTutor Admin
      </h2>
      <form id="loginForm" class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-medium text-slate-400 mb-2">Email</label>
          <input type="email" id="email" required placeholder="superadmin@trymytutor.com" value="superadmin@trymytutor.com"
            class="w-full px-4 py-3 bg-slate-900/50 border border-brand-border rounded-xl focus:outline-none focus:border-brand focus:ring-4 focus:ring-brand/20 transition-all text-white">
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-400 mb-2">Password</label>
          <div class="relative flex items-center">
            <input type="password" id="password" required placeholder="••••••••" value="Admin@123"
              class="w-full px-4 py-3 pr-12 bg-slate-900/50 border border-brand-border rounded-xl focus:outline-none focus:border-brand focus:ring-4 focus:ring-brand/20 transition-all text-white">
            <span class="absolute right-4 text-slate-400 cursor-pointer hover:text-white transition-colors"
              id="togglePassword">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </span>
          </div>
        </div>
        <button type="submit"
          class="w-full py-3.5 bg-gradient-to-r from-brand to-orange-600 rounded-xl font-semibold text-white shadow-lg shadow-brand/30 hover:-translate-y-1 hover:shadow-brand/50 transition-all active:translate-y-0">
          Login to Dashboard
        </button>
      </form>
      <p id="errorMsg" class="text-red-400 mt-4 text-center hidden text-sm"></p>
    </div>
  </div>


  <!-- ======================= -->
  <!--     DASHBOARD VIEW      -->
  <!-- ======================= -->
  <div class="view-section hidden" id="dashboardView">
    <div class="flex min-h-screen">

      <!-- Sidebar -->
      <aside class="w-64 glass-sidebar border-r border-brand-border flex flex-col justify-between py-8 h-screen sticky top-0 overflow-y-auto overflow-x-hidden">
