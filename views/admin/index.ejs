              <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Full
                  Name</label>
                <input type="text" id="tutorName" required
                  class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand text-white">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Email
                  Address</label>
                <input type="email" id="tutorEmail" required
                  class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand text-white">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Phone
                  Number</label>
                <input type="text" id="tutorPhone" pattern="^\d{10}$" title="Phone number must be exactly 10 digits"
