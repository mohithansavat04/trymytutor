              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Experience
                  (Years)</label>
                <input type="number" id="tutorExperience" min="0" value="0"
                  class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand text-white">
              </div>
