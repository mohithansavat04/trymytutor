<script>
  window.submitGenericForm = async function(moduleName) {
    const form = document.getElementById(moduleName.toLowerCase() + 'Form');
    if(!form) return;
    const id = document.getElementById(moduleName.toLowerCase() + 'Id').value;
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    const method = id ? 'PUT' : 'POST';
    const url = id ? `/api/admin/${moduleName.toLowerCase()}s/${id}` : `/api/admin/${moduleName.toLowerCase()}s`;
    
    try {
      const response = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + localStorage.getItem('adminToken')
        },
        body: JSON.stringify(data)
      });
      if(response.ok) {
        alert('Saved successfully!');
        document.getElementById(moduleName.toLowerCase() + 'Modal').classList.add('hidden');
        if(typeof window['fetch' + moduleName.charAt(0).toUpperCase() + moduleName.slice(1)] === 'function') {
           window['fetch' + moduleName.charAt(0).toUpperCase() + moduleName.slice(1)]();
        }
      } else {
        alert('Failed to save record.');
      }
    } catch(err) {
      console.error(err);
      alert('Error occurred.');
    }
  };
</script>

