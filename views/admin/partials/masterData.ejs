<div id="masterDataContent" class="view-section hidden">
  <div class="glass-card border border-brand-border rounded-2xl p-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 pb-6 border-b border-brand-border gap-4">
      <h3 class="text-xl font-bold">Master Data <span class="text-sm font-normal text-slate-400 block md:inline md:ml-2">Subjects, Classes, Boards, Schools</span></h3>
      
      <div class="flex flex-wrap gap-4 w-full md:w-auto">
        <select id="masterDataTypeFilter" class="bg-slate-900/50 border border-brand-border rounded-lg focus:outline-none focus:border-brand text-sm px-4 py-2 text-white">
          <option value="">All Types</option>
          <option value="subject">Subject</option>
          <option value="class">Class</option>
          <option value="board">Board</option>
          <option value="school">School</option>
        </select>
        
        <div class="relative flex-1 md:flex-none">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <input type="text" id="searchMasterData" placeholder="Search entries..." class="pl-10 pr-4 py-2 w-full bg-slate-900/50 border border-brand-border rounded-lg focus:outline-none focus:border-brand text-sm text-white">
        </div>

        <button id="openAddMasterDataModal" class="px-6 py-2.5 bg-brand text-white font-medium rounded-lg shadow-lg shadow-brand/30 hover:-translate-y-0.5 hover:shadow-brand/50 transition-all flex items-center whitespace-nowrap">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          Add Entry
        </button>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="text-xs uppercase tracking-wider text-slate-400 border-b border-brand-border/50 bg-slate-800/30">
            <th class="py-3 px-4 font-semibold">Type</th>
            <th class="py-3 px-4 font-semibold">Name</th>
            <th class="py-3 px-4 font-semibold">Status</th>
            <th class="py-3 px-4 font-semibold text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="masterDataTableBody" class="divide-y divide-brand-border/30">
          <!-- Populated dynamically -->
        </tbody>
      </table>
    </div>
    
    <div id="paginationMasterData" class="flex justify-between items-center mt-6 pt-4 border-t border-brand-border"></div>
  </div>
</div>

<!-- Master Data Form Modal -->
<div class="fixed inset-0 bg-slate-900/80 backdrop-blur-md z-50 hidden items-center justify-center transition-all opacity-0 modal-overlay p-4" id="masterDataFormModal">
  <div class="bg-slate-800 border border-brand-border rounded-3xl w-full max-w-lg transform scale-95 transition-all shadow-[0_0_60px_-15px_rgba(249,115,22,0.3)] relative overflow-hidden">
    <div class="p-8 relative bg-slate-800">
      <button id="closeMasterDataFormModal" class="absolute top-6 right-6 text-slate-400 hover:text-white transition-colors p-2 hover:bg-slate-700 rounded-full">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      
      <h3 class="text-2xl font-bold text-white mb-6" id="masterDataModalTitle">Add Entry</h3>
      
      <form id="masterDataForm" class="space-y-5">
        <input type="hidden" id="formMasterDataId">
        
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2">Type</label>
          <select id="formMasterDataType" class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand text-white transition-all shadow-inner" required>
            <option value="subject">Subject</option>
            <option value="class">Class</option>
            <option value="board">Board</option>
            <option value="school">School</option>
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2">Name</label>
          <input type="text" id="formMasterDataName" class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand text-white transition-all shadow-inner" required placeholder="e.g. Mathematics, Class 10, CBSE">
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2">Status</label>
          <select id="formMasterDataStatus" class="w-full px-4 py-3 bg-slate-900/60 border border-slate-700 rounded-xl focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand text-white transition-all shadow-inner" required>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
          </select>
        </div>

        <div class="flex gap-4 pt-4 mt-8 border-t border-slate-700">
          <button type="button" id="cancelMasterDataFormBtn" class="flex-1 py-3 px-4 bg-slate-700 hover:bg-slate-600 text-white font-medium rounded-xl transition-colors">Cancel</button>
          <button type="submit" class="flex-1 py-3 px-4 bg-brand hover:bg-brand/90 text-white font-medium rounded-xl shadow-lg shadow-brand/20 transition-transform hover:-translate-y-0.5">Save Entry</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Dynamic Generic Form Modal for masterData -->
<div id="masterdataModal" class="hidden fixed inset-0 z-50 overflow-y-auto bg-black bg-opacity-50">
  <div class="flex items-center justify-center min-h-screen px-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden transform transition-all">
      <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg leading-6 font-semibold text-gray-900" id="masterdataModalTitle">Create/Edit masterData</h3>
        <button onclick="document.getElementById('masterdataModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-500 focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="px-6 py-6">
        <form id="masterdataForm" class="space-y-4">
          <input type="hidden" id="masterdataId" name="id">
          <!-- Dynamic inputs will be injected here or generic fields -->
          <div class="form-group">
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select name="status" id="masterdataStatus" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
              <option value="Active">Active</option>
              <option value="Pending">Pending</option>
              <option value="Closed">Closed</option>
            </select>
          </div>
          <div class="form-group">
            <label class="block text-sm font-medium text-gray-700 mb-1">Notes / Description</label>
            <textarea name="description" id="masterdataNotes" rows="3" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"></textarea>
          </div>
        </form>
      </div>
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end space-x-3">
        <button type="button" onclick="document.getElementById('masterdataModal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Cancel</button>
        <button type="button" onclick="submitGenericForm('masterData')" class="px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">Save Changes</button>
      </div>
    </div>
  </div>
</div>
