<div id="demoCancellationsContent" class="view-section hidden animate-fade-in w-full">
  <div class="glass-card border border-brand-border/60 rounded-3xl p-8 shadow-[0_8px_30px_rgb(0,0,0,0.12)] backdrop-blur-md bg-slate-900/60">
    <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center mb-8 pb-6 border-b border-brand-border/40 gap-4">
      <div>
        <h3 class="text-3xl font-extrabold tracking-tight text-white mb-1 flex items-center gap-3">
          Demo Cancellations
          <span class="px-3 py-1 rounded-full bg-brand/20 text-brand text-xs font-bold uppercase tracking-widest border border-brand/30">Live</span>
        </h3>
        <p class="text-sm text-slate-400 font-medium">Manage and monitor your demo cancellations records</p>
      </div>
      
      <div class="flex flex-wrap gap-4 w-full xl:w-auto items-center">
        <div class="relative group flex-1 md:flex-none">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500 group-focus-within:text-brand transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <input type="text" id="searchdemoCancellations" placeholder="Search records..." class="pl-11 pr-4 py-3 bg-slate-900/80 border border-slate-700/80 rounded-xl focus:outline-none focus:border-brand focus:ring-4 focus:ring-brand/20 text-sm text-white w-full md:w-64 transition-all shadow-inner placeholder:text-slate-500">
        </div>
        <div class="flex gap-4">
          <button onclick="if(typeof fetchdemoCancellations === 'function') fetchdemoCancellations(); else if(typeof window.fetchDemoCancellations === 'function') window.fetchDemoCancellations();" class="px-5 py-3 bg-brand hover:bg-orange-500 text-white font-semibold rounded-xl shadow-[0_0_15px_rgba(249,115,22,0.3)] hover:shadow-[0_0_25px_rgba(249,115,22,0.5)] transition-all flex items-center gap-2 transform hover:-translate-y-0.5 whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            Refresh
          </button>
        </div>
      </div>
    </div>
    
    <div class="overflow-x-auto rounded-2xl border border-slate-700/50 shadow-inner bg-slate-900/40">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="text-xs uppercase tracking-widest text-slate-400 border-b border-slate-700/50 bg-slate-800/80">
            <th class="py-5 px-6 font-bold">Demo ID</th><th class="py-5 px-6 font-bold">Role</th><th class="py-5 px-6 font-bold">Penalty</th><th class="py-5 px-6 font-bold">Waiver</th><th class="py-5 px-6 font-bold">Date</th><th class="py-5 px-6 font-bold">Actions</th>
          </tr>
        </thead>
        <tbody id="demoCancellationsTableBody" class="divide-y divide-slate-700/30">
          <tr>
            <td colspan="6" class="py-16 text-center">
              <div class="flex flex-col items-center justify-center space-y-3">
                <div class="w-8 h-8 border-4 border-brand border-t-transparent rounded-full animate-spin"></div>
                <span class="text-slate-400 font-medium tracking-wide">Loading data...</span>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    
    <div id="paginationdemoCancellations" class="flex justify-between items-center mt-6 pt-6 border-t border-brand-border/40 text-sm text-slate-400 hidden">
      <span>Showing 1 to 10 of 100 entries</span>
      <div class="flex gap-2">
        <button class="px-3 py-1 bg-slate-800 rounded-lg hover:bg-slate-700 hover:text-white transition-colors">Prev</button>
        <button class="px-3 py-1 bg-slate-800 rounded-lg hover:bg-slate-700 hover:text-white transition-colors">Next</button>
      </div>
    </div>
  </div>
</div>
<!-- Dynamic Generic Form Modal for demoCancellations -->
<div id="democancellationsModal" class="hidden fixed inset-0 z-50 overflow-y-auto bg-black bg-opacity-50">
  <div class="flex items-center justify-center min-h-screen px-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden transform transition-all">
      <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
        <h3 class="text-lg leading-6 font-semibold text-gray-900" id="democancellationsModalTitle">Create/Edit demoCancellations</h3>
        <button onclick="document.getElementById('democancellationsModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-500 focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="px-6 py-6">
        <form id="democancellationsForm" class="space-y-4">
          <input type="hidden" id="democancellationsId" name="id">
          <!-- Dynamic inputs will be injected here or generic fields -->
          <div class="form-group">
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select name="status" id="democancellationsStatus" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
              <option value="Active">Active</option>
              <option value="Pending">Pending</option>
              <option value="Closed">Closed</option>
            </select>
          </div>
          <div class="form-group">
            <label class="block text-sm font-medium text-gray-700 mb-1">Notes / Description</label>
            <textarea name="description" id="democancellationsNotes" rows="3" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"></textarea>
          </div>
        </form>
      </div>
      <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end space-x-3">
        <button type="button" onclick="document.getElementById('democancellationsModal').classList.add('hidden')" class="px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Cancel</button>
        <button type="button" onclick="submitGenericForm('demoCancellations')" class="px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">Save Changes</button>
      </div>
    </div>
  </div>
</div>
